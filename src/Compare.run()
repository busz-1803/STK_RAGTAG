/**
 * Main Process
 */
static run() {

  try {

    Logger.info("===== COMPARE START =====");

    const sessionId = Config.get("CURRENT_SESSION");

    Validation.required(
      sessionId,
      "Current Session not found."
    );

    const version = this.getLatestVersion(sessionId);

    if (version === 0) {
      throw new Error("No Handheld data found.");
    }

    Logger.info("Session : " + sessionId);
    Logger.info("Version : " + version);

    // ล้างผล Compare เดิมของ Session/Version นี้
    this.clearResult(sessionId, version);

    // Compare
    const result = this.compare(
      sessionId,
      version
    );

    // Save DIFF_RESULT
    this.save(result);

    // Summary
    const summary =
      SummaryService.create(
        sessionId,
        version
      );

    SummaryService.save(
      sessionId,
      version,
      summary
    );

    // Report Location
    ReportLocationService.create(
      sessionId,
      version
    );

    Logger.info(
      "Compare Complete : " +
      result.length +
      " SKU"
    );

    SpreadsheetApp.getUi().alert(
      "Compare Complete\n\n" +
      "Session : " + sessionId +
      "\nVersion : " + version +
      "\nSKU : " + result.length
    );

  } catch (err) {

    Logger.error(err);

    SpreadsheetApp.getUi().alert(
      err.message
    );

  }

}
