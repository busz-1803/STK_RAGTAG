class DatabaseService {

  /**
   * Read Sheet
   */
  static table(sheetName) {

    return SheetService.getData(sheetName);

  }

  /**
   * STOCK_ONHAND
   */
  static getStocks(sessionId = null) {

    let rows = this.table(SHEET.STOCK);

    if (sessionId) {
      rows = rows.filter(r => r[0] == sessionId);
    }

    return rows.map(r => ({

      sessionId : r[0],
      store     : r[1],
      barcode   : Helper.barcode(r[2]),
      sku       : r[3],
      product   : r[4],
      color     : r[5],
      size      : r[6],
      qty       : Helper.toNumber(r[7]),
      price     : Helper.toNumber(r[8])

    }));

  }

  /**
   * PRODUCT_MASTER
   */
  static getProducts() {

    return this.table(SHEET.PRODUCT)
      .map(r => ({

        barcode : Helper.barcode(r[0]),
        sku     : r[1],
        product : r[2],
        brand   : r[3],
        color   : r[4],
        size    : r[5],
        status  : r[6]

      }));

  }

  /**
   * LOCATION_MASTER
   */
  static getLocations() {

    return this.table(SHEET.LOCATION)
      .map(r => ({

        barcode : Helper.barcode(r[0]),
        location: r[1]

      }));

  }

/**
 * Product Index
 */
static productIndex(){

    const index = {};

    this.getProducts().forEach(p=>{

        index[p.barcode]=p;

    });

    return index;

}

/**
 * Location Index
 */
static locationIndex(){

    const index={};

    this.getLocations().forEach(l=>{

        index[l.barcode]=l.location;

    });

    return index;

}
}
static joinStock(sessionId){

    const stocks=this.getStocks(sessionId);

    const product=this.productIndex();

    const location=this.locationIndex();

    return stocks.map(s=>({

        sessionId:s.sessionId,

        barcode:s.barcode,

        sku:s.sku,

        productName:
            product[s.barcode]?.product || s.product,

        color:
            product[s.barcode]?.color || s.color,

        size:
            product[s.barcode]?.size || s.size,

        location:
            location[s.barcode] || "",

        qty:s.qty,

        price:s.price

    }));

}
